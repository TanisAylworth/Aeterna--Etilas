var cc = global.char_creation; global.char_creation.tooltip.active = false; if (!is_struct(cc)) exit; if (!variable_struct_exists(cc, "steps")) exit; if (cc.step_index < 0 || cc.step_index >= array_length(cc.steps)) exit; var step = cc.steps[cc.step_index]; draw_text(20, 80, "SWITCH TEST"); switch (step.type) { case "single_select": draw_text(20, 100, "SPECIES STEP"); draw_species_select(step); break; case "roll_assign": draw_text(20, 100, "ATTRIBUTE STEP"); draw_attribute_step(step); break; case "multi_select_limited": draw_text(20, 100, "MULTI STEP"); draw_multi_select(step); break; default: draw_text(20, 100, "UNKNOWN STEP TYPE"); break; } var selected = global.char_creation.locked_species; draw_tooltip(); clear_tooltip(); var t = global.char_creation.tooltip; if (t.active) { var pad = 6; var w = string_width(t.text) + pad * 2; var h = string_height(t.text) + pad * 2; draw_set_color(make_color_rgb(0, 0, 0)); draw_rectangle(t.x, t.y, t.x + w, t.y + h, false); draw_set_color(c_white); draw_text(t.x + pad, t.y + pad, t.text); } if (global.char_creation.tooltip.active) { draw_text(global.char_creation.tooltip.x, global.char_creation.tooltip.y, global.char_creation.tooltip.text);



}